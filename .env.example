# Django
SECRET_KEY=your-secret-key-here
DJANGO_SETTINGS_MODULE=config.settings.dev

# Database (dev uses Docker defaults; prod set these to your external DB)
DB_NAME=foi_manager
DB_USER=foi_manager
DB_PASSWORD=foi_manager
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=llama3.2

# Email (SMTP)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=foi@example.com
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=foi@example.com

# FOI configuration
ORGANISATION_NAME=Your Organisation
FOI_REFERENCE_PREFIX=FOI
FOI_GDPR_RETENTION_YEARS=3

# Production only
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# CORS_ALLOWED_ORIGINS=https://staff.yourdomain.com,https://foi.yourdomain.com

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:8000
